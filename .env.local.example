# ══════════════════════════════════════════════════════
#  E-Orbit CRM — ملف الإعدادات
#  اعمل نسخة من الملف ده باسم:  .env.local
#  وحط فيه بياناتك من الـ JSON بتاع الـ Service Account
# ══════════════════════════════════════════════════════

# من الـ JSON بتاع الـ Service Account ← حقل client_email
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# من الـ JSON بتاع الـ Service Account ← حقل private_key (كاملاً مع BEGIN و END)
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEow...\n-----END RSA PRIVATE KEY-----\n"

# الـ ID من URL الـ Google Sheet
# مثال: https://docs.google.com/spreadsheets/d/[ هنا الـ ID ]/edit
GOOGLE_SHEET_ID=ضع_هنا_الـ_Sheet_ID
